# pnpm은 strict isolation이 기본이라 ESLint 플러그인이 여러 경로로 해석되면 충돌이 납니다.
# eslint-config-next와 @baneung-pack/eslint-config가 import 플러그인을 동시에 참조해도
# 동일 인스턴스를 보도록 호이스팅합니다.
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=@types/*

# Next.js + React peer 자동 설치
auto-install-peers=true

# CI publish 인증.
# 실제 토큰은 GitHub Actions의 NPM_TOKEN secret에서 주입된다.
# 로컬에서는 NPM_TOKEN이 없어도 public 패키지 설치는 정상 동작 (publish만 막힘).
//registry.npmjs.org/:_authToken=${NPM_TOKEN}
