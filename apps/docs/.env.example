# ────────────────────────────────────────────────────────────────────────
# Google Analytics 4
# ────────────────────────────────────────────────────────────────────────
# GA4 측정 ID (G-XXXXXXXXXX) — 미설정 시 gtag 스크립트 미주입 (로컬 dev 기본 동작).
# Vercel 등 production 환경에서만 설정 권장. GTM 거치지 않고 다이렉트 연동.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ────────────────────────────────────────────────────────────────────────
# SEO — Canonical 도메인
# ────────────────────────────────────────────────────────────────────────
# 배포 도메인. canonical URL / og:url / sitemap / JSON-LD 절대화에 사용.
# 미설정 시 placeholder(https://baneung-pack.dev) 사용.
NEXT_PUBLIC_SITE_URL=https://baneung-pack.dev

# ────────────────────────────────────────────────────────────────────────
# 프로젝트 문의 폼 (Resend)
# ────────────────────────────────────────────────────────────────────────
# Resend API 키 (필수) — https://resend.com 콘솔에서 발급.
# 미설정 시 /api/contact가 503 반환 → 폼 발송 시 "발송 중 오류" 노출.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 발신자 주소 (선택). 미설정 시 Resend 샌드박스 'onboarding@resend.dev' 사용.
# 운영에선 reacting.kr 같은 본인 소유 도메인을 Resend 콘솔에서 인증 후 입력 권장.
# 예: noreply@reacting.kr
CONTACT_FROM_EMAIL=onboarding@resend.dev

# 수신자 주소 (선택). 미설정 시 ash@reacting.kr 고정.
CONTACT_TO_EMAIL=ash@reacting.kr
