{
  "extends": ["@baneung-pack/eslint-config/react"],
  "rules": {
    "react/no-unknown-property": [
      "error",
      {
        "ignore": [
          "args",
          "attach",
          "position",
          "rotation",
          "scale",
          "rotation-x",
          "rotation-y",
          "rotation-z",
          "position-x",
          "position-y",
          "position-z",
          "intensity",
          "color",
          "castShadow",
          "receiveShadow",
          "shadow-mapSize-width",
          "shadow-mapSize-height",
          "roughness",
          "metalness",
          "anchorX",
          "anchorY",
          "outlineWidth",
          "outlineColor",
          "fontSize"
        ]
      }
    ]
  }
}
